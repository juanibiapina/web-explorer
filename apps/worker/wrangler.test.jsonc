// Wrangler config for integration tests.
// Same as wrangler.jsonc but without the AI binding (which requires remote
// mode and a Cloudflare login). The AI binding is never called in tests
// because explore/follow modules are mocked.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-explorer",
  "main": "./src/index.ts",
  "compatibility_date": "2025-07-09",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "INDEX_DO",
        "class_name": "IndexDO"
      },
      {
        "name": "EXPLORATION_DO",
        "class_name": "ExplorationDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ExplorerDO"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["IndexDO", "ExplorationDO"],
      "deleted_classes": ["ExplorerDO"]
    }
  ]
}
