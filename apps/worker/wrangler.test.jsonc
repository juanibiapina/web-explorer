// Wrangler config for integration tests.
// Same as wrangler.jsonc but without assets (no web build needed).
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-explorer",
  "main": "./src/index.ts",
  "compatibility_date": "2025-07-09",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "EXPLORER_DO",
        "class_name": "ExplorerDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["ExplorerDO"]
    }
  ]
}
