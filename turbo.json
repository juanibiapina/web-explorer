{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["CLOUDFLARE_API_TOKEN"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "outputs": []
    },
    "@repo/worker#test": {
      "dependsOn": ["@repo/web#build"],
      "outputs": []
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
